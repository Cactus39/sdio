.program dat_asm
.side_set 1

    wait 0 irq, 4       side 0
wait_loop:
    nop                side 0  [3]
    jmp pin wait_loop   side 1  [3] 
    
start:
    set x, 31           side 0
    nop                 side 0  [2]  
rx_loop:
    in  pins, 1         side 1 [3]
    jmp x-- rx_loop     side 0 [3]
    push    block       side 0
    jmp start           side 0 
